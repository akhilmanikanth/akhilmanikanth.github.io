      const bytes = await pdf.save();
      downloadBlob(new Blob([bytes], { type: 'application/pdf' }), 'metadata_updated.pdf');
      toast('Metadata saved!');
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
}
