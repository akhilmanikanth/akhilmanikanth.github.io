// ── EXTRACT TEXT ──
function toolExtractText() {
  modalBody.innerHTML = `
    ${dropZoneHTML('et')}
    <div class="action-bar"><button class="btn btn-primary" id="btnEt" disabled>Extract Text</button></div>
    <textarea id="etOutput" style="display:none;margin-top:1rem;min-height:250px;font-family:var(--mono);font-size:.8rem" readonly></textarea>
    <div class="action-bar" id="etActions" style="display:none"><button class="btn btn-secondary" id="btnEtCopy">Copy to Clipboard</button><button class="btn btn-secondary" id="btnEtDl">Download .txt</button></div>`;
  setupDropZone('et', () => { document.getElementById('btnEt').disabled = !loadedFiles.length; });
  document.getElementById('btnEt').addEventListener('click', async () => {
    try {
      const pdf = await pdfjsLib.getDocument({ data: loadedFiles[0].arrayBuffer.slice(0) }).promise;
      let fullText = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const pageText = content.items.map(item => item.str).join(' ');
        fullText += `--- Page ${i} ---\n${pageText}\n\n`;
      }
      const ta = document.getElementById('etOutput');
      ta.value = fullText; ta.style.display = 'block';
      document.getElementById('etActions').style.display = 'flex';
      toast(`Extracted text from ${pdf.numPages} pages`);
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
  document.getElementById('btnEtCopy').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('etOutput').value);
    toast('Copied to clipboard!');
  });
  document.getElementById('btnEtDl').addEventListener('click', () => {
    const blob = new Blob([document.getElementById('etOutput').value], { type: 'text/plain' });
    downloadBlob(blob, 'extracted_text.txt');
  });
}

// ── EXTRACT IMAGES ──
function toolExtractImages() {
  modalBody.innerHTML = `
    ${dropZoneHTML('ei')}
    <p style="font-size:.78rem;color:var(--text-dim);margin-top:.75rem">Renders each page as an image and lets you download them. For true embedded image extraction, a server-side tool is needed.</p>
    <div class="action-bar"><button class="btn btn-primary" id="btnEi" disabled>Extract Page Images</button></div>
    <div class="preview-area" id="eiPreview" style="display:none"></div>`;
  setupDropZone('ei', () => { document.getElementById('btnEi').disabled = !loadedFiles.length; });
  document.getElementById('btnEi').addEventListener('click', async () => {
    try {
      const pdf = await pdfjsLib.getDocument({ data: loadedFiles[0].arrayBuffer.slice(0) }).promise;
      const prev = document.getElementById('eiPreview');
      prev.style.display = 'flex'; prev.innerHTML = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const vp = page.getViewport({ scale: 2 });
        const canvas = document.createElement('canvas');
        canvas.width = vp.width; canvas.height = vp.height;
        await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
        const thumb = document.createElement('canvas');
        const tw = 140, th = (vp.height / vp.width) * tw;
        thumb.width = tw; thumb.height = th;
        thumb.getContext('2d').drawImage(canvas, 0, 0, tw, th);
        const div = document.createElement('div');
        div.className = 'preview-page';
        div.style.cursor = 'pointer';
        div.title = 'Click to download';
        div.appendChild(thumb);
        const num = document.createElement('div');
        num.className = 'page-num'; num.textContent = `Page ${i}`;
        div.appendChild(num);
        div.addEventListener('click', () => {
          canvas.toBlob(blob => downloadBlob(blob, `page_${i}.png`), 'image/png');
          toast(`Downloaded page ${i}`);
        });
        prev.appendChild(div);
      }
      toast('Click any thumbnail to download', 'info');
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
}

