    <div class="form-row">
      <div class="form-group"><label>Font Size</label><input type="number" id="pnSize" value="11" min="6" max="24"></div>
      <div class="form-group"><label>Start from page</label><input type="number" id="pnStart" value="1" min="1"></div>
    </div>
    <div class="action-bar"><button class="btn btn-primary" id="btnPn" disabled>Add Page Numbers</button></div>`;
  setupDropZone('pn', () => { document.getElementById('btnPn').disabled = !loadedFiles.length; });
  document.getElementById('btnPn').addEventListener('click', async () => {
    try {
      const pdf = await PDFDocument.load(loadedFiles[0].arrayBuffer);
      const font = await pdf.embedFont(StandardFonts.Helvetica);
      const pages = pdf.getPages();
      const total = pages.length;
      const pos = document.getElementById('pnPos').value;
      const fmt = document.getElementById('pnFmt').value;
      const size = parseInt(document.getElementById('pnSize').value);
      const startFrom = parseInt(document.getElementById('pnStart').value) - 1;
      pages.forEach((page, i) => {
        if (i < startFrom) return;
        const num = i - startFrom + 1;
        let text;
        if (fmt === 'num') text = `${num}`;
        else if (fmt === 'dash') text = `- ${num} -`;
        else text = `Page ${num} of ${total - startFrom}`;
        const { width, height } = page.getSize();
        const tw = font.widthOfTextAtSize(text, size);
        let x, y;
        if (pos.includes('left')) x = 40;
        else if (pos.includes('right')) x = width - tw - 40;
        else x = (width - tw) / 2;
        y = pos.includes('top') ? height - 30 : 25;
        page.drawText(text, { x, y, size, font, color: rgb(.3,.3,.3) });
      });
      const bytes = await pdf.save();
      downloadBlob(new Blob([bytes], { type: 'application/pdf' }), 'numbered.pdf');
      toast('Page numbers added!');
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
}

// ── SIGNATURE ──
function toolSign() {
  modalBody.innerHTML = `
    ${dropZoneHTML('sig')}
    <div class="form-group"><label>Draw your signature below</label></div>
    <canvas class="sign-canvas" id="sigCanvas"></canvas>
    <div class="form-row" style="margin-top:.75rem">
      <div class="form-group"><label>Place on page</label>
        <select id="sigPage"><option value="last">Last Page</option><option value="first">First Page</option><option value="all">All Pages</option></select></div>
      <div class="form-group"><label>Position</label>
        <select id="sigPos"><option value="bottom-right">Bottom Right</option><option value="bottom-left">Bottom Left</option><option value="bottom-center">Bottom Center</option></select></div>
    </div>
    <div class="action-bar">
      <button class="btn btn-secondary" id="btnSigClear">Clear</button>
      <button class="btn btn-primary" id="btnSig" disabled>Place Signature</button>
    </div>`;
  setupDropZone('sig', () => { document.getElementById('btnSig').disabled = !loadedFiles.length; });

  const canvas = document.getElementById('sigCanvas');
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth * 2;
  canvas.height = 400;
  ctx.scale(2, 2);
  ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.lineWidth = 2.5; ctx.strokeStyle = '#000';
  let drawing = false;
  canvas.addEventListener('pointerdown', e => { drawing = true; ctx.beginPath(); ctx.moveTo(e.offsetX, e.offsetY); });
  canvas.addEventListener('pointermove', e => { if (drawing) { ctx.lineTo(e.offsetX, e.offsetY); ctx.stroke(); } });
  canvas.addEventListener('pointerup', () => drawing = false);
  canvas.addEventListener('pointerleave', () => drawing = false);
  document.getElementById('btnSigClear').addEventListener('click', () => { ctx.clearRect(0, 0, canvas.width, canvas.height); });

  document.getElementById('btnSig').addEventListener('click', async () => {
    try {
      const pdf = await PDFDocument.load(loadedFiles[0].arrayBuffer);
      const sigDataUrl = canvas.toDataURL('image/png');
      const sigBytes = await fetch(sigDataUrl).then(r => r.arrayBuffer());
      const sigImg = await pdf.embedPng(sigBytes);
      const sigW = 180, sigH = (sigImg.height / sigImg.width) * sigW;
      const pages = pdf.getPages();
      const target = document.getElementById('sigPage').value;
      const pos = document.getElementById('sigPos').value;
      pages.forEach((page, i) => {
        if (target === 'first' && i !== 0) return;
        if (target === 'last' && i !== pages.length - 1) return;
        const { width } = page.getSize();
        let x;
        if (pos.includes('left')) x = 40;
        else if (pos.includes('right')) x = width - sigW - 40;
        else x = (width - sigW) / 2;
        page.drawImage(sigImg, { x, y: 40, width: sigW, height: sigH });
      });
      const bytes = await pdf.save();
      downloadBlob(new Blob([bytes], { type: 'application/pdf' }), 'signed.pdf');
      toast('Signature placed!');
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
}

// ── PROTECT ──
function toolProtect() {
  modalBody.innerHTML = `
    ${dropZoneHTML('prot')}
    <div class="form-row">
      <div class="form-group"><label>User Password (to open)</label><input type="password" id="protUser" placeholder="Password to open PDF"></div>
      <div class="form-group"><label>Owner Password (to edit)</label><input type="password" id="protOwner" placeholder="Password for editing rights"></div>
    </div>
    <p style="font-size:.78rem;color:var(--text-dim);margin-top:.5rem">Note: Browser-based encryption uses pdf-lib's built-in encryption. For maximum security, use a desktop tool.</p>
    <div class="action-bar"><button class="btn btn-primary" id="btnProt" disabled>🔒 Encrypt PDF</button></div>`;
  setupDropZone('prot', () => { document.getElementById('btnProt').disabled = !loadedFiles.length; });
  document.getElementById('btnProt').addEventListener('click', async () => {
    try {
      const pdf = await PDFDocument.load(loadedFiles[0].arrayBuffer);
      const userPass = document.getElementById('protUser').value;
      const ownerPass = document.getElementById('protOwner').value || userPass;
      if (!userPass) { toast('Enter at least a user password', 'error'); return; }
      pdf.encrypt({ userPassword: userPass, ownerPassword: ownerPass, permissions: { printing: 'lowResolution' } });
      const bytes = await pdf.save();
      downloadBlob(new Blob([bytes], { type: 'application/pdf' }), 'protected.pdf');
      toast('PDF encrypted!');
    } catch (e) { toast('Error: ' + e.message, 'error'); }
  });
}

